{
  "name": "grokadile-worker",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Cloudflare Worker backend for Grokadile: Grok (xAI) chat proxy + agent control plane.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:init": "wrangler d1 execute grokadile --file=./schema.sql",
    "db:init:local": "wrangler d1 execute grokadile --local --file=./schema.sql"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "wrangler": "^3.95.0"
  }
}
