<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Never back up secrets or the runtime agent DB to the cloud. -->
        <exclude domain="sharedpref" path="secure_prefs.xml" />
        <exclude domain="database" path="grokadile.db" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="secure_prefs.xml" />
    </device-transfer>
</data-extraction-rules>
